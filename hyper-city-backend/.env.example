# Local: 5000. Docker Compose forces PORT=10001 in docker-compose.yml (matches nginx).
PORT=5000
# Code accepts MONGO_URL or MONGO_URI (use one).
MONGO_URL=mongodb://localhost:27017/citysaathi
JWT_SECRET=change_this_jwt_secret
# CORS: exact browser origin (scheme + host + port). Production e.g. https://citysaathi.aeonsan.xyz
CLIENT_URL=http://localhost:3000
# http:// IP testing: set false. https:// production: omit (auto true from CLIENT_URL) or set true
COOKIE_SECURE=false
# Optional: none only with HTTPS + cross-site API; default lax for same-origin /api
# COOKIE_SAMESITE=lax
ADMIN_SIGNUP_SECRET=change_this_admin_signup_secret
